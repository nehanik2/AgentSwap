{
  "name": "@agentswap/agents",
  "version": "0.1.0",
  "private": true,
  "description": "AI buyer, seller, and arbitrator agents for AgentSwap",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentswap/ethereum": "workspace:*",
    "@agentswap/lightning": "workspace:*",
    "@agentswap/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.20.9",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5"
  }
}
