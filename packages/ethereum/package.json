{
  "name": "@agentswap/ethereum",
  "version": "0.1.0",
  "private": true,
  "description": "Ethereum HTLC smart contract + ethers.js client for AgentSwap",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.ts --network localhost",
    "deploy:agentswap": "npx hardhat run scripts/deployAgentSwapHTLC.ts --network localhost",
    "deploy:agentswap:sepolia": "npx hardhat run scripts/deployAgentSwapHTLC.ts --network sepolia"
  },
  "dependencies": {
    "@agentswap/shared": "workspace:*",
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "^1.0.10",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.12.0",
    "hardhat": "^2.22.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5"
  }
}
