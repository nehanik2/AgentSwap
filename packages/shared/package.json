{
  "name": "@agentswap/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for AgentSwap",
  "main": "./dist/types.js",
  "types": "./dist/types.d.ts",
  "files": ["types.ts", "dist"],
  "exports": {
    ".": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
