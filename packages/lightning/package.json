{
  "name": "@agentswap/lightning",
  "version": "0.1.0",
  "private": true,
  "description": "Lightning Network HTLC client — wraps LND REST API for AgentSwap",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentswap/shared": "workspace:*",
    "node-fetch": "^2.7.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/node-fetch": "^2.6.11",
    "typescript": "^5.4.5",
    "tsx": "^4.7.3"
  }
}
