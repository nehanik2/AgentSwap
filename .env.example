# =============================================================================
# AgentSwap — .env.example
#
# Copy this file to .env and fill in the values marked [REQUIRED].
# Values marked [AUTO] are written by scripts/start-demo.sh — you can leave
# them blank initially; they will be populated into .env.local at runtime.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   bash scripts/start-demo.sh
# =============================================================================


# ── AI / LLM ─────────────────────────────────────────────────────────────────

# [REQUIRED] Anthropic API key for all three agent roles (buyer, seller, arbitrator).
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# [OPTIONAL] Anthropic model to use for agent reasoning.
# Default: claude-3-5-sonnet-20241022  (best cost/quality balance for agentic tasks)
# Alternatives: claude-3-opus-20240229 (slower, more capable)
#               claude-3-haiku-20240307 (fastest, cheapest — good for demos)
AGENT_MODEL=claude-3-5-sonnet-20241022


# ── Bitcoin / Lightning ───────────────────────────────────────────────────────

# [OPTIONAL] Bitcoin Core RPC credentials — must match docker-compose.yml.
# Defaults are fine for local regtest.
BITCOIN_RPC_USER=agentswap
BITCOIN_RPC_PASS=agentswap

# [AUTO] Buyer LND REST API URL.
# Written by start-demo.sh after LND containers start.
# Override if your LND is running outside Docker.
BUYER_LND_REST_URL=https://localhost:8080

# [AUTO] Seller LND REST API URL (host port 8081 maps to container 8080).
SELLER_LND_REST_URL=https://localhost:8081

# [AUTO] Absolute path to the buyer LND TLS certificate.
# Copied from the Docker container by start-demo.sh.
BUYER_LND_TLS_CERT_PATH=./.lnd-certs/buyer-tls.cert

# [AUTO] Absolute path to the seller LND TLS certificate.
SELLER_LND_TLS_CERT_PATH=./.lnd-certs/seller-tls.cert

# [OPTIONAL] LND macaroon hex strings.
# Leave blank if running with --no-macaroons (the docker-compose default).
BUYER_LND_MACAROON_HEX=
SELLER_LND_MACAROON_HEX=

# ── LNDClient env vars (packages/lightning/src/lndClient.ts) ─────────────────
# These mirror the BUYER/SELLER vars above but use the naming expected by
# the LNDClient integration tests and agent layer.
# The macaroon here is base64-encoded (Docker LND export format).
# Leave blank when running with --no-macaroons.

# Buyer LND node (REST gateway, host port 8080)
LND_BUYER_URL=https://localhost:8080
LND_BUYER_MACAROON=

# Seller LND node (REST gateway, host port 8081)
LND_SELLER_URL=https://localhost:8081
LND_SELLER_MACAROON=


# ── Ethereum ──────────────────────────────────────────────────────────────────

# [OPTIONAL] Ethereum JSON-RPC endpoint.
# Default: local Ganache via docker-compose.
ETH_RPC_URL=http://localhost:8545

# [AUTO] Deployed HashedTimelockETH contract address.
# Written to .env.local by packages/ethereum/scripts/deploy.ts after deployment.
ETH_HTLC_CONTRACT_ADDRESS=

# [REQUIRED for Sepolia / mainnet] Private key of the buyer's Ethereum account.
# For local Ganache the default mnemonic's Account[0] key is pre-filled below.
# ⚠️  NEVER use a mainnet key with real funds here.
# Default (Ganache Account[0] — Hardhat/Ganache well-known test key, NOT secret):
ETH_BUYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Default (Ganache Account[1]):
ETH_SELLER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Corresponding public addresses (used in contract calls as recipient).
ETH_BUYER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
ETH_SELLER_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# [OPTIONAL] Ethereum mnemonic for Ganache deterministic accounts.
# Must match the --wallet.mnemonic in docker-compose.yml.
# Default is the BIP-39 "abandon×11 + about" test mnemonic.
ETH_MNEMONIC=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about


# ── Sepolia (optional — only needed if deploying to testnet) ──────────────────

# [OPTIONAL] Alchemy / Infura Sepolia RPC URL.
# Only needed if you run: pnpm --filter @agentswap/ethereum deploy:sepolia
SEPOLIA_RPC_URL=


# ── Dashboard ─────────────────────────────────────────────────────────────────

# [OPTIONAL] Port for the Next.js dashboard.
PORT=3000

# [OPTIONAL] Next.js telemetry opt-out.
NEXT_TELEMETRY_DISABLED=1
