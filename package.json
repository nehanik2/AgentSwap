{
  "name": "agentswap",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-chain atomic swap escrow system with AI agent negotiation",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "pnpm --filter @agentswap/shared build && pnpm -r --filter !@agentswap/shared build",
    "dev": "pnpm --filter @agentswap/shared build && pnpm -r --parallel --filter !@agentswap/shared dev",
    "typecheck": "pnpm --filter @agentswap/shared build && pnpm -r --filter !@agentswap/shared typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "demo": "bash scripts/start-demo.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "preflight": "tsx scripts/preflight-check.ts",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:happy": "vitest run --config vitest.config.ts tests/integration/happyPath.test.ts",
    "test:refund": "vitest run --config vitest.config.ts tests/integration/refundPath.test.ts",
    "test:atomic": "vitest run --config vitest.config.ts tests/integration/atomicGuarantee.test.ts",
    "simulate-demo": "tsx scripts/simulate-full-demo.ts",
    "reset-demo": "bash scripts/reset-demo-env.sh"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.5",
    "tsx": "^4.7.3",
    "prettier": "^3.2.5",
    "eslint": "^9.1.1",
    "vitest": "^1.6.0",
    "ethers": "^6.11.1"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.4.5"
    }
  }
}
